{
  "name": "tiktok-video-uploader",
  "version": "1.0.0",
  "description": "A Node.js application that monitors a folder for videos and pushes them to a Supabase queue",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node --max-old-space-size=16384 --expose-gc dist/index.js",
    "dev": "node --max-old-space-size=16384 --expose-gc -r ts-node/register -r tsconfig-paths/register src/index.ts",
    "watch": "ts-node -r tsconfig-paths/register --watch src/index.ts",
    "clean": "rm -rf dist",
    "install:pnpm": "pnpm install",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo:caching": "node -r tsconfig-paths/register -r ts-node/register src/scripts/demonstrateCaching.ts"
  },
  "packageManager": "pnpm@8.15.0",
  "keywords": [
    "tiktok",
    "video",
    "upload",
    "queue",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@torbox/torbox-api": "^1.0.9",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/sharp": "^0.32.0",
    "axios": "^1.12.2",
    "cookie": "^1.0.2",
    "dotenv": "^16.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "sharp": "^0.34.4",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.0",
    "@types/node": "^20.19.17",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}